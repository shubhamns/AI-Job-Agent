ENVIRONMENT=local
API_BASE_URL=http://localhost:8000/api/v1
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_job_agent
JWT_SECRET_KEY=replace-with-a-real-secret
REFRESH_TOKEN_EXPIRE_DAYS=7
RESUME_UPLOAD_DIR=./uploads/resumes
MAX_RESUME_FILE_SIZE_BYTES=5242880
CORS_ORIGINS=http://localhost:5173
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=in
ADZUNA_BASE_URL=https://api.adzuna.com
ADZUNA_RESULTS_PER_PAGE=20
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=local-dev-webhook-secret
TELEGRAM_MODE=polling
CRON_ENABLED=true
JOB_CHECK_DAILY_HOUR=9
JOB_CHECK_TIMEZONE=Asia/Kolkata
